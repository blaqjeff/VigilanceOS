{
  "version": "0.1",
  "type": "container",
  "meta": {
    "trigger": "api",
    "system_resources": {
      "required_vram": 24
    }
  },
  "ops": [
    {
      "type": "container/run",
      "id": "vllm-qwen27b",
      "args": {
        "image": "docker.io/vllm/vllm-openai:cu130-nightly",
        "gpu": true,
        "expose": 8000,
        "cmd": [
          "--model",
          "cyankiwi/Qwen3.5-27B-AWQ-4bit",
          "--served-model-name",
          "Qwen3.5-27B-AWQ-4bit",
          "--gpu-memory-utilization",
          "0.8",
          "--enforce-eager",
          "--host",
          "0.0.0.0",
          "--port",
          "8000",
          "--max-model-len",
          "2048"
        ]
      }
    }
  ]
}
