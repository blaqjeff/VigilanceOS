{
  "name": "nosana-eliza-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start:eliza": "node ./scripts/run-eliza.mjs start",
    "dev:eliza": "npm run build:backend && node ./scripts/run-eliza.mjs dev",
    "dev:ui": "npm --prefix ui run dev",
    "start:ui": "npm --prefix ui run start",
    "dev": "node ./scripts/run-stack.mjs dev",
    "dev:stack": "powershell.exe -ExecutionPolicy Bypass -File ./scripts/run-stack.ps1 -Mode dev",
    "start": "node ./scripts/run-stack.mjs start",
    "start:stack": "powershell.exe -ExecutionPolicy Bypass -File ./scripts/run-stack.ps1 -Mode start",
    "stop": "node ./scripts/stop-stack.mjs",
    "stop:stack": "powershell.exe -ExecutionPolicy Bypass -File ./scripts/run-stack.ps1 -Mode stop",
    "build:ui": "npm --prefix ui run build",
    "build:backend": "tsc -p tsconfig.json",
    "build": "npm run build:backend",
    "build:all": "npm run build:backend && npm run build:ui",
    "install:all": "npm install && npm install --prefix ui",
    "reinstall:all": "npm install --force && npm install --prefix ui --force"
  },
  "dependencies": {
    "@elizaos/core": "1.7.2",
    "@elizaos/plugin-anthropic": "1.5.12",
    "@elizaos/plugin-bootstrap": "1.7.2",
    "@elizaos/plugin-mcp": "1.7.1",
    "@elizaos/plugin-openai": "1.6.0",
    "@elizaos/server": "1.7.2",
    "@elizaos/plugin-telegram": "1.6.4",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3"
  },
  "devDependencies": {
    "@elizaos/cli": "1.7.2",
    "typescript": "^5.0.0"
  }
}
